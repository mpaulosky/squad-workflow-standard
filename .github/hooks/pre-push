#!/usr/bin/env bash
# Pre-push gate for squad-workflow-standard
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; CYAN='\033[0;36m'; RESET='\033[0m'

echo -e "${CYAN}━━━ Pre-Push Gate ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"

# Read push refs from stdin (provided by git when run as a hook).
PUSH_REFS="$(cat || true)"

# Allow tag-only pushes.
if [[ -n "$PUSH_REFS" ]] && echo "$PUSH_REFS" | grep -q "^refs/tags/"; then
  if ! echo "$PUSH_REFS" | grep -qv "^refs/tags/"; then
    echo -e "${GREEN}✅ Tag push — skipping branch gates.${RESET}"
    exit 0
  fi
fi

CURRENT_BRANCH="$(git symbolic-ref --short HEAD 2>/dev/null || echo "")"
if [[ "$CURRENT_BRANCH" == "main" || "$CURRENT_BRANCH" == "dev" ]]; then
  echo -e "${RED}❌ Direct pushes to '${CURRENT_BRANCH}' are not allowed.${RESET}"
  exit 1
fi

if ! [[ "$CURRENT_BRANCH" =~ ^(squad|sprint)/[0-9]+-[a-z0-9-]+$ ]]; then
  echo -e "${RED}❌ Branch name '${CURRENT_BRANCH}' does not match naming convention.${RESET}"
  echo -e "   Expected: ${YELLOW}squad/{issue-number}-{kebab-slug}${RESET} or ${YELLOW}sprint/{n}-{kebab-slug}${RESET}"
  exit 1
fi

UPSTREAM=""
if git rev-parse --abbrev-ref --symbolic-full-name '@{u}' >/dev/null 2>&1; then
  UPSTREAM="$(git rev-parse --abbrev-ref --symbolic-full-name '@{u}')"
fi

if [[ -n "$UPSTREAM" ]]; then
  mapfile -t CHANGED_YAML < <(git diff --name-only "${UPSTREAM}...HEAD" -- '*.yml' '*.yaml')
  mapfile -t CHANGED_MD < <(git diff --name-only "${UPSTREAM}...HEAD" -- '*.md')
else
  mapfile -t CHANGED_YAML < <(git diff --name-only HEAD~1..HEAD -- '*.yml' '*.yaml' 2>/dev/null || true)
  mapfile -t CHANGED_MD < <(git diff --name-only HEAD~1..HEAD -- '*.md' 2>/dev/null || true)
fi

if [[ ${#CHANGED_YAML[@]} -gt 0 ]]; then
  echo -e "\n${CYAN}🧩 YAML lint on changed workflow files...${RESET}"
  YAML_CONFIG_FILE="$(mktemp)"
  cat > "$YAML_CONFIG_FILE" <<'EOF'
extends: default
ignore: |
  .squad/
rules:
  line-length:
    max: 200
    allow-non-breakable-inline-mappings: true
  truthy:
    allowed-values: ['true', 'false', 'on']
  brackets:
    min-spaces-inside: 0
    max-spaces-inside: 1
EOF

  if command -v yamllint >/dev/null 2>&1; then
    yamllint -c "$YAML_CONFIG_FILE" "${CHANGED_YAML[@]}"
  elif command -v docker >/dev/null 2>&1; then
    docker run --rm \
      -v "$ROOT:/work" \
      -v "$YAML_CONFIG_FILE:/tmp/yamllint.yml:ro" \
      -w /work \
      cytopia/yamllint:latest \
      -c /tmp/yamllint.yml "${CHANGED_YAML[@]}"
  else
    echo -e "${RED}❌ yamllint is not available.${RESET}"
    rm -f "$YAML_CONFIG_FILE"
    exit 1
  fi
  rm -f "$YAML_CONFIG_FILE"
  echo -e "${GREEN}✅ YAML lint OK.${RESET}"
else
  echo -e "\n${GREEN}✅ No changed YAML files to lint.${RESET}"
fi

if [[ ${#CHANGED_MD[@]} -gt 0 ]]; then
  echo -e "\n${CYAN}📝 Markdown lint on changed docs...${RESET}"
  npx --yes markdownlint-cli2 "${CHANGED_MD[@]}"
  echo -e "${GREEN}✅ Markdown lint OK.${RESET}"
else
  echo -e "\n${GREEN}✅ No changed Markdown files to lint.${RESET}"
fi

echo -e "\n${CYAN}🧪 Running test suite...${RESET}"
dotnet test squad-workflow-standard.slnx --nologo
echo -e "${GREEN}✅ Test suite OK.${RESET}"

echo -e "\n${GREEN}━━━ All gates passed — pushing ✅ ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}\n"
