#!/usr/bin/env bash
# Pre-commit gate: runs markdownlint on staged .md files.
# Blocks the commit if any markdownlint violations are found.
# Degrades gracefully if markdownlint binary is not available.
set -uo pipefail

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; CYAN='\033[0;36m'; RESET='\033[0m'

# ── Collect staged .md files ───────────────────────────────────────────────
STAGED_MD=$(git diff --cached --name-only --diff-filter=ACM | grep '\.md$' || true)

if [[ -z "$STAGED_MD" ]]; then
  exit 0
fi

echo -e "${CYAN}━━━ Pre-Commit Markdownlint Gate ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"

# ── Probe for markdownlint binary ──────────────────────────────────────────
MARKDOWNLINT_BIN=""

if command -v markdownlint &>/dev/null; then
  MARKDOWNLINT_BIN="markdownlint"
elif [[ -x "$ROOT/node_modules/.bin/markdownlint-cli2" ]]; then
  MARKDOWNLINT_BIN="$ROOT/node_modules/.bin/markdownlint-cli2"
elif [[ -x "$ROOT/node_modules/.bin/markdownlint" ]]; then
  MARKDOWNLINT_BIN="$ROOT/node_modules/.bin/markdownlint"
fi

if [[ -z "$MARKDOWNLINT_BIN" ]]; then
  echo -e "${YELLOW}⚠️   markdownlint not found — skipping markdown lint check.${RESET}"
  echo -e "    To enable: run  ${CYAN}npm install${RESET}  (markdownlint-cli2 is a dev dependency)"
  echo -e "    Or install globally: ${CYAN}npm install -g markdownlint-cli2${RESET}"
  exit 0
fi

# ── Run markdownlint on staged files ──────────────────────────────────────
echo -e "  Linting staged .md files with: ${CYAN}$(basename "$MARKDOWNLINT_BIN")${RESET}"

# Build array of files and run linter
mapfile -t MD_FILES <<< "$STAGED_MD"

CONFIG_FLAG=""
if [[ -f "$ROOT/.markdownlint.json" ]]; then
  if [[ "$(basename "$MARKDOWNLINT_BIN")" == "markdownlint-cli2" ]]; then
    CONFIG_FLAG="--config $ROOT/.markdownlint.json"
  else
    CONFIG_FLAG="--config $ROOT/.markdownlint.json"
  fi
fi

# shellcheck disable=SC2086
if "$MARKDOWNLINT_BIN" $CONFIG_FLAG "${MD_FILES[@]}" 2>&1; then
  echo -e "${GREEN}✅  All staged .md files passed markdownlint.${RESET}"
  exit 0
else
  echo -e ""
  echo -e "${RED}❌  Markdownlint violations found in staged files above.${RESET}"
  echo -e "    Fix the violations and re-stage the files before committing."
  echo -e "    To skip in an emergency: ${YELLOW}git commit --no-verify${RESET}"
  exit 1
fi
